{
  "name": "nylon-impossible",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "wrangler d1 migrations apply nylon-impossible-db --local --persist-to .wrangler/state -c src/api/wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply nylon-impossible-db --remote -c src/api/wrangler.jsonc",
    "db:generate": "drizzle-kit generate --config src/api/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config src/api/drizzle.config.ts",
    "db:push": "drizzle-kit push --config src/api/drizzle.config.ts",
    "db:reset": "./scripts/db-reset.sh",
    "db:seed": "wrangler d1 execute nylon-impossible-db --local --persist-to .wrangler/state -c src/api/wrangler.jsonc --file=src/api/src/db/seeds/seed.sql",
    "db:fresh": "./scripts/db-reset.sh && pnpm db:seed",
    "db:backup": "./scripts/db-backup.sh",
    "db:status": "wrangler d1 migrations list nylon-impossible-db --local --persist-to .wrangler/state -c src/api/wrangler.jsonc",
    "db:export:remote": "wrangler d1 export nylon-impossible-db --remote --output .wrangler/backups/remote-export.sql -c src/api/wrangler.jsonc",
    "dev": "pnpm --parallel --filter @nylon-impossible/web --filter @nylon-impossible/api dev",
    "dev:remote": "pnpm web:dev:remote & pnpm api:dev:remote & wait",
    "test": "pnpm web:test && pnpm api:test",
    "lint": "pnpm web:lint && pnpm api:lint",
    "format": "pnpm web:format && pnpm api:format",
    "check": "pnpm web:check && pnpm api:check",
    "typecheck": "pnpm web:typecheck && pnpm api:typecheck",
    "deploy": "pnpm web:deploy && pnpm api:deploy",
    "web:open": "code 'src/web'",
    "web:dev": "pnpm --filter @nylon-impossible/web dev",
    "web:dev:remote": "pnpm --filter @nylon-impossible/web dev:remote",
    "web:build": "pnpm --filter @nylon-impossible/web build",
    "web:test": "pnpm --filter @nylon-impossible/web test",
    "web:typecheck": "pnpm --filter @nylon-impossible/web typecheck",
    "web:lint": "pnpm --filter @nylon-impossible/web lint",
    "web:format": "pnpm --filter @nylon-impossible/web format",
    "web:check": "pnpm --filter @nylon-impossible/web check",
    "web:deploy": "pnpm --filter @nylon-impossible/web run deploy",
    "api:test": "pnpm --filter @nylon-impossible/api test",
    "api:dev": "pnpm --filter @nylon-impossible/api dev",
    "api:dev:remote": "pnpm --filter @nylon-impossible/api dev:remote",
    "api:deploy": "pnpm --filter @nylon-impossible/api run deploy",
    "api:typecheck": "pnpm --filter @nylon-impossible/api typecheck",
    "api:lint": "pnpm --filter @nylon-impossible/api lint",
    "api:format": "pnpm --filter @nylon-impossible/api format",
    "api:check": "pnpm --filter @nylon-impossible/api check",
    "ios:open": "open 'src/ios/Nylon Impossible/Nylon Impossible.xcodeproj'",
    "ios:build": "xcodebuild -project 'src/ios/Nylon Impossible/Nylon Impossible.xcodeproj' -scheme 'Nylon Impossible' -configuration Debug build",
    "ios:simulator": "open -a Simulator"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "drizzle-kit": "^0.31.8",
    "wrangler": "^4.40.3"
  }
}
