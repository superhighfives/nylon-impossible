{
  "name": "@nylon-impossible/admin",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3100",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --config-path ../..",
    "lint:fix": "biome lint --write --config-path ../..",
    "format": "biome format --write --config-path ../..",
    "check": "biome check --config-path ../..",
    "check:fix": "biome check --write --config-path ../..",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.30.0",
    "@tailwindcss/vite": "^4.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.3",
    "wrangler": "^4.40.3"
  }
}
