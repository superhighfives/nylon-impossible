{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nylon-impossible-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nylon-impossible-db",
      "database_id": "effd712c-bc6e-4536-bddd-735b56502080",
      "migrations_dir": "../web/migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "USER_SYNC",
        "class_name": "UserSync"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["UserSync"]
    }
  ],
  "queues": {
    "producers": [
      { "binding": "RESEARCH_QUEUE", "queue": "nylon-impossible-research" }
    ]
  },
  // AI Gateway vars for mocked tests. Actual values not needed since extractTodos is mocked.
  "vars": {
    "CF_ACCOUNT_ID": "test-account",
    "AI_GATEWAY_ID": "test-gateway",
    "CLOUDFLARE_API_TOKEN": "test-token"
  },
  "observability": {
    "enabled": true
  }
}
