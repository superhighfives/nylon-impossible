# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# AI Gateway ID
AI_GATEWAY_ID=nylon-impossible

# Cloudflare API (Optional)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_token_here

# Tavily web search (required for the research feature — no Workers AI
# model performs real web search yet, so we ground summaries on Tavily
# results to avoid fabricated URLs). Sign up at https://tavily.com.
# In production, set via: wrangler secret put TAVILY_API_KEY
TAVILY_API_KEY=your_tavily_key_here
