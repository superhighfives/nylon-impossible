{
  "name": "@nylon-impossible/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --persist-to ../../.wrangler/state",
    "dev:remote": "wrangler dev --remote --persist-to ../../.wrangler/state",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --config-path ../..",
    "lint:fix": "biome lint --write --config-path ../..",
    "format": "biome format --write --config-path ../..",
    "check": "biome check --config-path ../..",
    "check:fix": "biome check --write --config-path ../..",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.3",
    "@nylon-impossible/shared": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "fractional-indexing": "^3.2.0",
    "hono": "^4.12.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.40.3"
  }
}
