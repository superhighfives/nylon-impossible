# Which API the web client talks to during local dev.
# Default: the local API worker.
VITE_API_BASE_URL=http://localhost:8787

# To develop the frontend against the deployed production API (real data),
# set this instead — or just run `pnpm dev:prod`, which sets it for you:
# VITE_API_BASE_URL=https://api.nylonimpossible.com
