default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )

    build_number = ENV["BUILD_NUMBER"] || Time.now.to_i.to_s

    # Write API key to temp file for xcodebuild auth
    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
    api_key_path = File.join(Dir.tmpdir, "AuthKey_#{key_id}.p8")
    File.write(api_key_path, ENV["APP_STORE_CONNECT_API_KEY_CONTENT"])

    archive_path = File.join(Dir.tmpdir, "NylonImpossible.xcarchive")
    export_path = File.join(Dir.tmpdir, "NylonImpossible-export")
    export_options_path = File.join(Dir.tmpdir, "ExportOptions.plist")

    # Step 1: Archive with automatic signing + -allowProvisioningUpdates
    # Requires Apple Development cert in keychain. API key auth lets xcodebuild
    # talk to App Store Connect for provisioning on CI.
    # sh() runs from fastlane/ dir, so project path needs ../
    archive_cmd = [
      "xcodebuild", "archive",
      "-project", "../Nylon Impossible.xcodeproj",
      "-scheme", "Nylon Impossible",
      "-configuration", "Release",
      "-archivePath", archive_path,
      "-destination", "generic/platform=iOS",
      "CURRENT_PROJECT_VERSION=#{build_number}",
      "API_BASE_URL=#{ENV['API_BASE_URL'] || 'https://api.nylonimpossible.com'}",
      "-allowProvisioningUpdates",
      "-authenticationKeyID", key_id,
      "-authenticationKeyIssuerID", ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      "-authenticationKeyPath", api_key_path
    ]
    if ENV["SPM_CACHE_PATH"]
      archive_cmd += ["-clonedSourcePackagesDirPath", ENV["SPM_CACHE_PATH"]]
    end
    sh(*archive_cmd)

    # Step 2: Export WITHOUT -allowProvisioningUpdates (manual signing)
    File.write(export_options_path, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key>
        <string>app-store-connect</string>
        <key>signingStyle</key>
        <string>manual</string>
        <key>teamID</key>
        <string>#{ENV.fetch("TEAM_ID")}</string>
        <key>signingCertificate</key>
        <string>Apple Distribution</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>com.superhighfives.Nylon-Impossible</key>
          <string>Nylon Impossible AppStore</string>
          <key>com.superhighfives.Nylon-Impossible.Nylon-Share</key>
          <string>Nylon Share AppStore</string>
        </dict>
      </dict>
      </plist>
    PLIST

    sh(
      "xcodebuild", "-exportArchive",
      "-archivePath", archive_path,
      "-exportOptionsPlist", export_options_path,
      "-exportPath", export_path
    )

    # Step 3: Upload to TestFlight
    ipa_path = Dir.glob(File.join(export_path, "*.ipa")).first
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end
end
