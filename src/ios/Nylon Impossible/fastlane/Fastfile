default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )

    build_number = ENV["BUILD_NUMBER"] || Time.now.to_i.to_s

    # Write API key to a temp file for xcodebuild automatic signing
    api_key_path = File.join(Dir.tmpdir, "AuthKey.p8")
    File.write(api_key_path, ENV["APP_STORE_CONNECT_API_KEY_CONTENT"])

    xcargs = [
      "CURRENT_PROJECT_VERSION=#{build_number}",
      "-allowProvisioningUpdates",
      "-authenticationKeyPath #{api_key_path}",
      "-authenticationKeyID #{ENV['APP_STORE_CONNECT_API_KEY_ID']}",
      "-authenticationKeyIssuerID #{ENV['APP_STORE_CONNECT_API_ISSUER_ID']}"
    ].join(" ")

    build_app(
      project: "Nylon Impossible.xcodeproj",
      scheme: "Nylon Impossible",
      configuration: "Release",
      export_method: "app-store",
      xcargs: xcargs,
      cloned_source_packages_path: ENV["SPM_CACHE_PATH"],
      skip_profile_detection: true,
      export_options: {
        signingStyle: "manual",
        teamID: "TGHU37N6EX",
        installerSigningCertificate: "Apple Distribution: David  Charles Gleason (TGHU37N6EX)",
        provisioningProfiles: {
          "com.superhighfives.Nylon-Impossible" => ENV["PROVISIONING_PROFILE_NAME"] || "Nylon Impossible AppStore"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
